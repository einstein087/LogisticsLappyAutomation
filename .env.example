# Copy this file to .env and fill in your values.
# Do NOT commit .env to source control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:5000

# Database (leave blank to use the default SQLite lappy.db)
# Example: DATABASE_URL=dialect+driver://server/database_name

# SMTP / Email (Office 365 example)
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=servicedesk@yourcompany.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=servicedesk@yourcompany.com

# Approval link expiry (seconds, default 7 days)
APPROVAL_TOKEN_MAX_AGE=604800

# Microsoft Graph / SharePoint (optional - leave blank to skip upload)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_FOLDER_PATH=Compliance Reports/Laptop Provisioning

# Weekly report schedule
REPORT_DAY_OF_WEEK=mon
REPORT_HOUR=7
REPORT_MINUTE=0
